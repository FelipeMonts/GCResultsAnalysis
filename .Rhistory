data = Cum.Plot.Data,
pch =16,
main="CO2",
auto.key = T,
panel=function(x, y, ...){
panel.xyplot(x, y, ...)
panel.text(x=x, y=y,
labels= rownames(Cum.Plot.Data),
pos=1)
})
